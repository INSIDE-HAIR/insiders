# Database
DATABASE_URL="mongodb://localhost:27017/video-conferencing-platform"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-here"

# Token Encryption
ENCRYPTION_KEY="your-32-character-encryption-key-here"

# Google OAuth (existing)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google Meet API (can be same as above or separate)
GOOGLE_MEET_CLIENT_ID="your-google-meet-client-id"
GOOGLE_MEET_CLIENT_SECRET="your-google-meet-client-secret"
GOOGLE_MEET_REDIRECT_URI="http://localhost:3000/api/video-conferencing/oauth/callback"

# Zoom API
ZOOM_CLIENT_ID="your-zoom-client-id"
ZOOM_CLIENT_SECRET="your-zoom-client-secret"
ZOOM_ACCOUNT_ID="your-zoom-account-id"
ZOOM_REDIRECT_URI="http://localhost:3000/api/video-conferencing/oauth/callback"

# Vimeo API
VIMEO_CLIENT_ID="your-vimeo-client-id"
VIMEO_CLIENT_SECRET="your-vimeo-client-secret"
VIMEO_REDIRECT_URI="http://localhost:3000/api/video-conferencing/oauth/callback"

# GitHub OAuth (existing)
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Webhook Secrets (optional)
WEBHOOK_SECRET_MEET="your-meet-webhook-secret"
WEBHOOK_SECRET_ZOOM="your-zoom-webhook-secret"
WEBHOOK_SECRET_VIMEO="your-vimeo-webhook-secret"